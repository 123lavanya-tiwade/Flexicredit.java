# abstract class
abstract class Shape {
    abstract void draw();
}

class Circle extends Shape {
    void draw() {
        System.out.println("Circle");
    }

    public static void main(String[] args) {
        new Circle().draw();
    }
}

#interface
interface A {
    void show();
}

class B implements A {
    public void show() {
        System.out.println("Interface method");
    }

    public static void main(String[] args) {
        new B().show();
    }
}

