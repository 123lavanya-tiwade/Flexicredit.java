#parameter passing
class Demo {
    void change(int x) {
        x = 100;
    }

    public static void main(String[] args) {
        int a = 10;
        Demo d = new Demo();
        d.change(a);
        System.out.println(a); // unchanged
    }
}

# Arrays
class Demo {
    public static void main(String[] args) {
        int[] arr = {1,2,3};

        for(int i : arr)
            System.out.println(i);
    }
}

#Garbage collector
class Demo {
    protected void finalize() {
        System.out.println("Object destroyed");
    }

    public static void main(String[] args) {
        Demo d = new Demo();
        d = null;
        System.gc();
    }
}

#Inner class
class Outer {
    class Inner {
        void show() {
            System.out.println("Inner class");
        }
    }

    public static void main(String[] args) {
        Outer o = new Outer();
        Outer.Inner i = o.new Inner();
        i.show();
    }
}
